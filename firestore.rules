rules_version = '2';

// AVM TempoCerto — Firestore Security Rules
// Modelo de dados:
//   users/{uid}                              -> perfil do usuário (read/write próprio)
//   users/{uid}/scenarios/{scenarioId}       -> cenários salvos pelo usuário
//
// Princípios:
//   - Nenhum acesso anônimo ou cross-user.
//   - Cada usuário só lê/escreve dentro do próprio documento `users/{uid}`.
//   - Escritas são permitidas apenas se o UID do token auth casar com o path.
//   - Qualquer outro path é bloqueado por padrão (deny-all implícito).

service cloud.firestore {
  match /databases/{database}/documents {

    // Função utilitária: usuário autenticado e dono do recurso
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Perfil do usuário
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Cenários salvos (subcoleção)
      match /scenarios/{scenarioId} {
        allow read, write: if isOwner(uid);
      }

      // Qualquer subcoleção futura sob users/{uid} herda a mesma regra
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Deny-all para qualquer outro caminho
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
